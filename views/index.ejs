<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>AuggieMap – Route Info</title>

  <!-- Optional CSS -->
  <link rel="stylesheet" href="/css/main.css">
</head>
<body>

  <div class="info">
    <h2>Walking / walking Directions</h2>

    <p>
      <strong>Distance:</strong>
      <%= (distance / 1000).toFixed(2) %> km
    </p>

    <p>
      <strong>Estimated Time:</strong>
      <%= Math.round(duration / 60) %> minutes
    </p>

    <% if (summary && summary.length > 0) { %>
      <p>
        <strong>Route Summary:</strong>
        <%= summary %>
      </p>
    <% } else { %>
      <p>
        <strong>Route Summary:</strong>
        Not available
      </p>
    <% } %>
  </div>

</body>
</html>
